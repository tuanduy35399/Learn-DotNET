@model IEnumerable<Practice2.Models.SINHVIEN>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>


    @Html.ActionLink("Create New", "Create")
</p>
@using (Html.BeginForm("TimKiem", "Home", FormMethod.Get))
{
    <p>
        @ViewBag.LabelTimKiem:
        @Html.DropDownList("id", (SelectList)ViewData["TimKiem"], "--- Chọn sinh viên ---")
        <input type="submit" value="Lọc" class="btn btn-primary" />
        @Html.ActionLink("Tất cả", "Index", null, new { @class = "btn btn-default" })
    </p>
}
@{

    var grid = new WebGrid(source: Model, canPage: true, rowsPerPage: 2);
}
<div id="gridContent">
    @grid.GetHtml(
        tableStyle: "table table-bordered table-striped", // Tái sử dụng class CSS cũ
        headerStyle: "info",
        footerStyle: "pagination",
        columns: grid.Columns(
            grid.Column("TENHOCVIEN", "Tên Học Viên"),
            grid.Column("EMAIL", "Email"),
            grid.Column("DIENTHOAI", "Điện thoại"),
            grid.Column(header: "Chức năng", format: (item) =>
                new HtmlString(
                    Html.ActionLink("Sửa", "Edit", new { id = item.MAHOCVIEN }) + " | " +
                    Html.ActionLink("Xóa", "Delete", new { id = item.MAHOCVIEN }) + " | " +
                    Html.ActionLink("Xem chi tiết", "Details", new {id= item.MAHOCVIEN})
                )
            )
        )
    )
</div>
